generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  SELLER
}

model Store {
  id        String     @id @default(cuid())
  name      String
  users     User[]
  medicines Medicine[]
  sales     Sale[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  role         UserRole
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sessions     Session[]
  sales        Sale[]    @relation("SellerSales")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model Medicine {
  id          String     @id @default(cuid())
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  category    String
  price       Float
  stock       Int
  image       String?
  instructions String
  expiryDate  DateTime
  saleItems   SaleItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([storeId])
}

model Sale {
  id           String     @id @default(cuid())
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sellerUserId String
  seller       User       @relation("SellerSales", fields: [sellerUserId], references: [id], onDelete: Restrict)
  subtotal     Float
  discount     Float      @default(0)
  total        Float
  cash         Float
  change       Float
  items        SaleItem[]
  createdAt    DateTime   @default(now())

  @@index([storeId, createdAt])
}

model SaleItem {
  id           String   @id @default(cuid())
  saleId       String
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medicineId   String
  medicine     Medicine @relation(fields: [medicineId], references: [id], onDelete: Restrict)
  nameSnapshot String
  price        Float
  quantity     Int
  total        Float
}
